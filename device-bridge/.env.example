# Point this at your Doc'O Clock ingest edge function
DOC_O_CLOCK_INGEST_URL=https://tthzcijscedgxjfnfnky.functions.supabase.co/device-bridge-ingest

# Your hospital's institution UUID (from Doc'O Clock → Institution → Settings)
INSTITUTION_ID=00000000-0000-0000-0000-000000000000

# HMAC token = HMAC-SHA256(DEVICE_BRIDGE_SECRET, INSTITUTION_ID) — paste the
# value shown in Doc'O Clock → Institution → Devices → "Pair bridge".
BRIDGE_TOKEN=

# Path to the device inventory manifest
DEVICES_FILE=./devices.json

# Optional: bind interface (default 0.0.0.0)
BIND_HOST=0.0.0.0
