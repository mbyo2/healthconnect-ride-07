# Required for every platform (Netlify, Vercel, Docker, or a static host).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional. The app falls back to 112 when this is not set.
# Set this to the emergency number appropriate to your deployed region.
VITE_EMERGENCY_NUMBER=112
